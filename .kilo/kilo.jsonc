{
  "$schema": "https://app.kilo.ai/config.json",

  // Per-model OpenRouter options. Everything under `options` is forwarded
  // verbatim to the OpenRouter API as providerOptions.openrouter.
  "provider": {
    "openrouter": {
      "models": {
        // Debug mode: max reasoning for hard troubleshooting.
        // Watch the OpenRouter dashboard — xhigh can burn 20–50K reasoning
        // tokens per request. Drop to "high" if costs get out of hand.
        "deepseek/deepseek-v4-pro": {
          "options": {
            "reasoning": {
              "effort": "xhigh",
              "exclude": false
            },
            "include_reasoning": true
          }
        },

        // Code mode: medium reasoning. /speckit.implement is mechanical
        // work and heavy reasoning is mostly wasted overhead here.
        "moonshotai/kimi-k2.6": {
          "options": {
            "reasoning": {
              "effort": "medium",
              "exclude": false
            },
            "include_reasoning": true
          }
        },

        // Plan/Architect mode: high reasoning for spec decomposition.
        "z-ai/glm-5.1": {
          "options": {
            "reasoning": {
              "effort": "high",
              "exclude": false
            },
            "include_reasoning": true
          }
        },

        // Ask mode: no reasoning config — keep this fast and cheap.
        "qwen/qwen-3.6-27b": {
          "options": {}
        }
      }
    }
  },

  // Don't route through Kilo's own gateway; use OpenRouter directly.
  "disabled_providers": [
    "kilo"
  ],

  // Hackathon convenience — auto-approve bash. Tighten for production.
  "permission": {
    "bash": "allow"
  },

  // Per-mode model assignments. Switching modes (Cmd+. / Ctrl+.) in the
  // Kilo chat box auto-switches the underlying model.
  "agent": {
    "plan": {
      "model": "openrouter/z-ai/glm-5.1"
    },
    "code": {
      "model": "openrouter/moonshotai/kimi-k2.6"
    },
    "debug": {
      "model": "openrouter/deepseek/deepseek-v4-pro"
    },
    "ask": {
      "model": "openrouter/qwen/qwen-3.6-27b"
    }
  },

  "indexing": {
    "enabled": true
  },

  // Global default — prefer low-latency OpenRouter providers over peak
  // throughput. Helps avoid landing on a cold/slow backend during
  // interactive sessions.
  "options": {
    "provider": {
      "sort": "latency"
    }
  }
}
